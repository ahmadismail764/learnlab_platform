@startuml ClassDiagram

' --- Page 1: User Hierarchy ---

class User {
    id
    email
    passwordHash
    + updateEmail()
    + updatePassword()
}

class Admin {
}

class Student {
    xp : int
    ' getAnalytics was crossed out in the sketch
    + {method} <strike>getAnalytics()</strike>
    + addXp()
    + getXp()
}

