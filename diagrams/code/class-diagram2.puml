end note

class "Topic Mastery" as TopicMastery {
    studentId
    topicId
    difficulty
    stability
    lastReviewDate
    create leaderboard
}

' Relationships inferred from IDs
Question --> Topic : topic_id
TopicMastery --> Student : studentId
TopicMastery --> Topic : topicId

