# ============================================================
# Root .env - values used by docker-compose.yml only
# ============================================================

# Postgres superuser password used by the db service.
POSTGRES_SUPERUSER_PASSWORD=change_me_in_production

# Password for the application DB user created by init.sql.
LEARNLAB_APP_DB_PASSWORD=change_me_in_production

# Published host ports.
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Frontend build arg. In Compose, Nginx is the same-origin gateway.
VITE_API_BASE_URL=/api/v1
