# ============================================================
# Root .env — values used by docker-compose.yml only
# ============================================================
# Postgres superuser password (used by the db service and the backend service)
# ============================================================
POSTGRES_SUPERUSER_PASSWORD=change_me_in_production

# Frontend build arg — URL the browser uses to reach the API
# The example is what you should use in local development.
# Change it to your server's IP or domain when deploying anywhere other than localhost.
VITE_API_BASE_URL=http://localhost:8000

# Port the frontend nginx container is exposed on.
FRONTEND_PORT=5173
