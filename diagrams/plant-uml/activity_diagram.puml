@startuml
start
:Student initiates Practice Session;

partition "AI Scheduler (FSRS)" {
    :Fetch User History;
    :Calculate Topic Stability;
    if (Stability < 5?) then (Low Retention)
        :Select Tier 1 (Definitions/Concepts);
    elseif (Stability < 20?) then (Medium)
        :Select Tier 2 (Application);
    else (High Retention)
        :Select Tier 3 (Synthesis/Proof);
    endif
}

partition "Problem Generator" {
    :Load Problem Template;
    :Randomize Variables & Sets;
    :Render MathLive Interface;
}

:Student Attempts Problem;

if (Student needs help?) then (yes)
    :Click "Get AI Hint";
    :AI Analyzes current input state;
    :Display Progressive Hint;
    detach
endif

:Student Submits Answer;

partition "Grading Engine" {
    if (Is Answer Correct?) then (Yes)
        :Calculate XP (Tier * Multiplier);
        :Update Streak;
    else (No)
        :Identify Error Type;
        :Fetch Remedial Micro-Video;
    endif
    
    :Update FSRS Memory State;
    :Recalculate Next Review Date;
}

stop
@enduml