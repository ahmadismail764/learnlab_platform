# ==============================================================================
# DJANGO CORE CONFIGURATION
# ==============================================================================
# Set to True for local development, False for production
DEBUG=True

# Generate a fresh one for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-replace-this-with-a-very-long-64-character-random-string-in-production

# Comma-separated list of domains. Localhost is handled automatically when DEBUG=True.
# Example for prod: api.yourdomain.com
ALLOWED_HOSTS=

# ==============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==============================================================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=pick_db_name
DB_USER=pick_username_other_than_postgres
DB_PASSWORD=insert_password
DB_HOST=localhost
DB_PORT=5432

# ==============================================================================
# REDIS CONFIGURATION
# ==============================================================================
# Used for caching analytics endpoints. In Docker, use redis://redis:6379/1
REDIS_URL=redis://127.0.0.1:6379/1

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
# Comma-separated list of frontend URLs allowed to make API requests.
# Example: http://localhost:5173,https://yourfrontend.com
CORS_ALLOWED_ORIGINS=

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================
# Use console backend in dev (prints to stdout), smtp for production.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# ==============================================================================
# AI / EXTERNAL SERVICES
# ==============================================================================
# Required for PDF question extraction feature.
GEMINI_API_KEY=your_gemini_api_key_here

# Used in password reset emails. Set to your frontend's public URL in production.
FRONTEND_URL=http://localhost:5173 No newline at end of file