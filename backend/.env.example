# ==============================================================================
# DJANGO CORE CONFIGURATION
# ==============================================================================
# Set to True for local development, False for production
DEBUG=True

# A unique, unpredictable secret key. (Generate a fresh one for production!)
SECRET_KEY=django-insecure-replace-this-with-a-very-long-64-character-random-string-in-production

# Comma-separated list of domains your server is allowed to serve.
# Local development handles localhost automatically if DEBUG=True.
# Example for prod: api.yourdomain.com,yourdomain.com
ALLOWED_HOSTS=

# ==============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==============================================================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=pick_db_name
DB_USER=pick_username_other_than_postgres
DB_PASSWORD=insert_password
DB_HOST=you_should_know_that
DB_PORT=you_sould_also_know_that

# ==============================================================================
# CORS CONFIGURATION (Next Step)
# ==============================================================================
# Comma-separated list of absolute frontend URLs allowed to make API requests.
# Example: https://yourfrontend.com,https://www.yourfrontend.com
CORS_ALLOWED_ORIGINS=read_about_this_or_watch_a_video_on_it

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================
# Leave defaults to use the console backend (prints emails to stdout) in dev.
# Switch to smtp for production or use a service like Brevo/Mailgun/SES.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com