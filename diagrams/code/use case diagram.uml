@startuml
' Layout Settings
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

' Define Actors
actor "Student" as Student
actor "Admin" as Admin

rectangle "LearnLab Platform" {

    ' Common Use Case
    usecase "UC-01/02: Register / Login" as UC_Auth

    ' Student Features Group
    rectangle "Student Features" #LightBlue {
        usecase "UC-03: Solve Practice Sheet\n(Adaptive Session)" as UC_PracticeSheet
        usecase "UC-06: View Leaderboard\n(XP & Streaks)" as UC_Leaderboard
        usecase "UC-08: View Topics\n(Dashboard & Progress)" as UC_Topics
        usecase "Watch Explanation Video\n(Optional Support)" as UC_WatchVideo
    }
    
    ' Admin Features Group
    rectangle "Admin Features" #LightGreen {
        usecase "UC-04: View Student Analytics\n(FSRS Insights)" as UC_Analytics
        usecase "UC-05: Manage Question Bank\n(CRUD & Scaffolding Tiers)" as UC_QuestionBank
        usecase "UC-07: Manage Topics\n(Curriculum Structure)" as UC_ManageTopics
    }
    
    ' Components Group
    rectangle "Practice Sheet Components" #LightYellow {
        usecase "Solve Single Question" as UC_SolveQuestion
        usecase "Rate Confidence\n(1-5 for FSRS)" as UC_RateConfidence
        usecase "Submit Practice Sheet" as UC_Submit
    }
}

' --- Associations ---

' Student interactions
Student --> UC_Auth
Student --> UC_Leaderboard
Student --> UC_Topics
Student --> UC_PracticeSheet

' Admin interactions
Admin --> UC_Auth
Admin --> UC_Analytics
Admin --> UC_ManageTopics
Admin --> UC_QuestionBank

' --- Logic Relationships ---

' UC-03 Alternate Flow 3a: Video is optional during practice
UC_WatchVideo .> UC_PracticeSheet : <<extend>>

' UC-08 Main Scenario Step 6: Dashboard leads to practice
UC_Topics .> UC_PracticeSheet : <<trigger>>

' UC-03 Main Scenario: Practice involves questions and submission
UC_PracticeSheet ..> UC_Submit : <<include>>
UC_PracticeSheet ..> UC_SolveQuestion : <<include>>

' Class Diagram / UC-03 logic: Every question requires a confidence rating for FSRS
UC_SolveQuestion ..> UC_RateConfidence : <<include>>

@enduml